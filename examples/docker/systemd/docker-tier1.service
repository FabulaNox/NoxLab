[Unit]
Description=Docker tier 1 (apps) - starts after ingress is up
After=docker-tier0.service
Requires=docker-tier0.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/docker/tier1
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target
